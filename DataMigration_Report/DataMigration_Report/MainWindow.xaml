<Window x:Class="WpfFolderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Selector" Height="200" Width="400">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Select a Target Folder:" FontWeight="Bold"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74*"/>
                    <ColumnDefinition Width="211*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Name="txtFolderPath" Grid.Column="0" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0" Grid.ColumnSpan="2"/>
                <Button Name="btnBrowse" Content="Browse..." Grid.Column="2" Width="75" Click="btnBrowse_Click"/>
            </Grid>

            <Button Name="btnConfirm" Content="Confirm Action" Height="30" Margin="0,10,0,0" Click="btnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>